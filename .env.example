# ── PokémonTCG API ────────────────────────────────────────────────
# Optional — a free key from https://dev.pokemontcg.io raises your rate limit.
# POKEMONTCG_API_KEY=your-key-here

# Override the default API base URL (e.g. when migrating to Scrydex):
# POKEMONTCG_API_BASE=https://api.pokemontcg.io/v2

# Override the default API search query (Base Set):
# POKEMONTCG_DEFAULT_QUERY='name:"Charizard"'

# ── eBay Developer API (preferred) ───────────────────────────────
# Apply at: https://developer.ebay.com/develop/apis
# When both are set, the pipeline uses the Browse API instead of scraping.
# EBAY_APP_ID=your-client-id
# EBAY_CERT_ID=your-client-secret
# EBAY_API_ENVIRONMENT=production

# ── eBay Scraper (fallback) ──────────────────────────────────────
# EBAY_DEFAULT_SEARCH_TERM=Charizard Base Set 4/102
# EBAY_REQUEST_DELAY=3.0
# EBAY_MAX_RETRIES=3

# ── Logging ───────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG
